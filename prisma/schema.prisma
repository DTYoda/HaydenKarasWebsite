generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Skills {
  id          String @id @default(cuid())
  category    String
  name        String
  description String
  proficiency Int    @default(80)
}

model Education {
  id          String @id @default(cuid())
  category    String
  name        String
  description String
  link        String
  linkText    String
}

model Projects {
  id           String @id @default(cuid())
  urlTitle     String
  title        String
  descriptions String
  images       String
  links        String
  technologies String @default("[]")
  type         String @default("website")
  date         String @default("undefined")
}

model StaticContent {
  id          String @id @default(cuid())
  key         String @unique
  title       String?
  content     String
  section     String
}

model TopSkills {
  id          String @id @default(cuid())
  name        String
  proficiency Int
  category    String
  order       Int    @default(0)
}

model QuickStats {
  id       String @id @default(cuid())
  value    String
  label    String
  sublabel String
  order    Int    @default(0)
}

model PageContent {
  id      String @id @default(cuid())
  key     String @unique
  page    String
  section String
  content String
  type    String @default("text")
}
